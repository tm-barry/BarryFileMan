<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:vm="using:BarryFileMan.ViewModels">
	<!-- Preview DataTemplate -->
	<Design.PreviewWith>
		<Grid Width="600" Height="450">
			<Grid.Resources>
				<ResourceDictionary>
					<ResourceDictionary.MergedDictionaries>
						<ResourceInclude Source="/Views/FlattenViewTemplate.axaml"/>
					</ResourceDictionary.MergedDictionaries>
				</ResourceDictionary>
			</Grid.Resources>
			<Grid.DataTemplates>
				<StaticResource ResourceKey="flattenView"/>
			</Grid.DataTemplates>

			<ContentControl>
				<vm:FlattenViewModel/>
			</ContentControl>
		</Grid>
	</Design.PreviewWith>

	<DataTemplate x:Key="flattenView" x:DataType="vm:FlattenViewModel">
		<Grid>
			<TextBlock Text="Flatten" HorizontalAlignment="Center" VerticalAlignment="Center"/>
		</Grid>
	</DataTemplate>
</ResourceDictionary>

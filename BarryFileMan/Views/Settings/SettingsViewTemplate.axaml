<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:vm="using:BarryFileMan.ViewModels.Settings"
					xmlns:lang="using:BarryFileMan.Resources"
					xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia">

	<!-- Preview DataTemplate -->
	<Design.PreviewWith>
		<Grid Width="600" Height="450">
			<Grid.Resources>
				<ResourceDictionary>
					<ResourceDictionary.MergedDictionaries>
						<ResourceInclude Source="/Views/Settings/SettingsViewTemplate.axaml"/>
					</ResourceDictionary.MergedDictionaries>
				</ResourceDictionary>
			</Grid.Resources>
			<Grid.DataTemplates>
				<StaticResource ResourceKey="settingsView"/>
			</Grid.DataTemplates>

			<ContentControl>
				<vm:SettingsViewModel/>
			</ContentControl>
		</Grid>
	</Design.PreviewWith>
	
	<DataTemplate x:Key="settingsView" x:DataType="vm:SettingsViewModel">
		<Grid RowDefinitions="*,Auto">
			<ScrollViewer Grid.Row="0">
				<StackPanel>
					<!--General-->
					<TextBlock FontWeight="Bold" Margin="10,5,5,5"
							   Text="{x:Static lang:Resources.General}"/>
					<Border BorderThickness="2" CornerRadius="3" Padding="10"
							BorderBrush="{DynamicResource SystemBaseMediumColor}">
						<Grid ColumnDefinitions="*,*" 
							  RowDefinitions="Auto,Auto,Auto,Auto,Auto">
							<!--Config Path-->
							<TextBlock Grid.Column="0" Grid.Row="0" Margin="10,0,0,0"
									   VerticalAlignment="Center"
									   Text="{x:Static lang:Resources.ConfigPath}"/>
							<Grid Grid.Column="1" Grid.Row="0"
								  ColumnDefinitions="*,Auto">
								<Border Grid.Column="0"
										BorderBrush="{DynamicResource SystemBaseMediumColor}"
										CornerRadius="3,0,0,3"
										BorderThickness="1">
									<ScrollViewer MaxHeight="57">
										<SelectableTextBlock Margin="3"
															 Text="{Binding Config.General.ConfigPath}"
															 TextWrapping="Wrap"
															 Background="Transparent"
															 HorizontalAlignment="Stretch"/>
									</ScrollViewer>
								</Border>
								<Button Grid.Column="1"
										Width="45"
										VerticalAlignment="Stretch"
										CornerRadius="0,3,3,0"
										Command="{Binding CopyTextCommand}"
										CommandParameter="{Binding Config.General.ConfigPath}">
									<Panel>
										<materialIcons:MaterialIcon Kind="ContentCopy"/>
									</Panel>
								</Button>
							</Grid>

							<Separator Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10,0,10"/>
							
							<!--Theme-->
							<TextBlock Grid.Column="0" Grid.Row="2" Margin="10,0,0,0"
									   VerticalAlignment="Center"
									   Text="{x:Static lang:Resources.Theme}"/>
							<ComboBox Grid.Column="1" Grid.Row="2"
									  HorizontalAlignment="Stretch"
									  ItemsSource="{Binding Config.General.Themes}"
									  SelectedIndex="{Binding Config.General.SelectedThemeIndex}">
								<ComboBox.ItemTemplate>
									<DataTemplate>
										<StackPanel Orientation="Horizontal" Margin="5">
											<materialIcons:MaterialIcon Height="24" Width="24"
																		Kind="{Binding Icon}"/>
											<TextBlock Margin="10,0,0,0"
													   Text="{Binding Display}"
													   VerticalAlignment="Center"/>
										</StackPanel>
									</DataTemplate>
								</ComboBox.ItemTemplate>
							</ComboBox>
							
							<Separator Grid.Row="3" Grid.ColumnSpan="2" Margin="0,10,0,10"/>

							<!--Sidebar Expanded Default-->
							<TextBlock Grid.Column="0" Grid.Row="4" Margin="10,0,0,0"
									   VerticalAlignment="Center"
									   Text="{x:Static lang:Resources.SidebarExpandedDefault}"/>
							<CheckBox Grid.Column="1" Grid.Row="4" Margin="0,0,10,0"
									  HorizontalAlignment="Left"
									  IsChecked="{Binding Config.General.SidebarExpandedDefault}"/>
						</Grid>
					</Border>

					<!--Rename-->
					<TextBlock FontWeight="Bold" Margin="10,20,5,5"
							   Text="{x:Static lang:Resources.Rename}"/>
					<Border BorderThickness="2" CornerRadius="3" Padding="10"
							BorderBrush="{DynamicResource SystemBaseMediumColor}">
						<Grid ColumnDefinitions="*,*">
							<!--Default Load Option-->
							<TextBlock Grid.Column="0" Margin="10,0,0,0"
									   Text="{x:Static lang:Resources.DefaultLoadOption}" 
									   VerticalAlignment="Center"/>							
							<ComboBox Grid.Column="1" Grid.Row="0"
									  HorizontalAlignment="Stretch"
									  ItemsSource="{Binding Config.Rename.RenameLoadOptions}"
									  SelectedIndex="{Binding Config.Rename.SelectedDefaultLoadOptionIndex}">
								<ComboBox.ItemTemplate>
									<DataTemplate>
										<StackPanel Orientation="Horizontal" Margin="5">
											<materialIcons:MaterialIcon Height="24" Width="24"
																		Kind="{Binding Icon}"/>
											<TextBlock Margin="10,0,0,0"
													   Text="{Binding Display}"
													   VerticalAlignment="Center"/>
										</StackPanel>
									</DataTemplate>
								</ComboBox.ItemTemplate>
							</ComboBox>
						</Grid>
					</Border>

					<!--Flatten-->
					<TextBlock FontWeight="Bold" Margin="10,20,5,5"
							   Text="{x:Static lang:Resources.Flatten}"/>
					<Border BorderThickness="2" CornerRadius="3" Padding="10"
							BorderBrush="{DynamicResource SystemBaseMediumColor}">
						<Grid ColumnDefinitions="*,*"
							  RowDefinitions="Auto,Auto,Auto,Auto,Auto">
							<!--Regex File Filter Default-->
							<TextBlock Grid.Column="0" Grid.Row="0" Margin="10,0,0,0"
									   VerticalAlignment="Center"
									   Text="{x:Static lang:Resources.DefaultRegexFileFilter}"/>
							<TextBox Grid.Column="1" Grid.Row="0"
									 Text="{Binding Config.Flatten.DefaultRegexFileFilter}"
									 PlaceholderText="{x:Static lang:Resources.FlattenRegexFileFilterWatermark}"/>

							<Separator Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10,0,10"/>

							<!--Delete Excluded Files Default-->
							<TextBlock Grid.Column="0" Grid.Row="2" Margin="10,0,0,0"
									   VerticalAlignment="Center"
									   Text="{x:Static lang:Resources.DeleteExcludedFilesDefault}"/>
							<CheckBox Grid.Column="1" Grid.Row="2" Margin="0,0,10,0"
									  HorizontalAlignment="Left"
									  IsChecked="{Binding Config.Flatten.DeleteExcludedFilesDefault}"/>

							<Separator Grid.Row="3" Grid.ColumnSpan="2" Margin="0,10,0,10"/>

							<!--Delete Empty Folders Default-->
							<TextBlock Grid.Column="0" Grid.Row="4" Margin="10,0,0,0"
									   VerticalAlignment="Center"
									   Text="{x:Static lang:Resources.DeleteEmptyFoldersDefault}"/>
							<CheckBox Grid.Column="1" Grid.Row="4" Margin="0,0,10,0"
									  HorizontalAlignment="Left"
									  IsChecked="{Binding Config.Flatten.DeleteEmptyFoldersDefault}"/>
						</Grid>
					</Border>

					<!--TMDB-->
					<Image Grid.Column="0" Margin="10,20,5,5" Height="16"
						   HorizontalAlignment="Left"
						   Source="/Assets/tmdb-alt-short-logo.124x16.png"/>
					<Border BorderThickness="2" CornerRadius="3" Padding="10"
							BorderBrush="{DynamicResource SystemBaseMediumColor}">
						<Grid ColumnDefinitions="*,*"
							  RowDefinitions="Auto,Auto,Auto">
							<!--API Key-->
							<TextBlock Grid.Column="0" Grid.Row="0" Margin="10,0,0,0"
									   VerticalAlignment="Center"
									   Text="{x:Static lang:Resources.ApiKey}"/>
							<TextBox Grid.Column="1" Grid.Row="0"
									 Text="{Binding Config.Tmdb.ApiKey}"
									 PasswordChar="*"
									 PlaceholderText="{x:Static lang:Resources.TmdbApiKeyWatermark}"/>

							<Separator Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10,0,10"/>

							<!--Include Adult-->
							<TextBlock Grid.Column="0" Grid.Row="2" Margin="10,0,0,0"
									   VerticalAlignment="Center"
									   Text="{x:Static lang:Resources.IncludeAdult}"/>
							<CheckBox Grid.Column="1" Grid.Row="2" Margin="0,0,10,0"
									  HorizontalAlignment="Left"
									  IsChecked="{Binding Config.Tmdb.IncludeAdult}"/>
						</Grid>
					</Border>
				</StackPanel>
			</ScrollViewer>

			<Button Grid.Row="1" Margin="0,10,0,5" Height="32"
					HorizontalAlignment="Left"
					Command="{Binding RevertToDefaultCommand}">
				<Grid ColumnDefinitions="Auto,*">
					<materialIcons:MaterialIcon Grid.Column="0" Kind="CogRefresh"/>
					<TextBlock Grid.Column="1" Margin="5,0,0,0" VerticalAlignment="Center" Text="{x:Static lang:Resources.Default}"/>
				</Grid>
			</Button>

			<StackPanel Grid.Row="1" Margin="0,10,0,5"
						Orientation="Horizontal"
						HorizontalAlignment="Right">
				<Button Height="32"
						Command="{Binding UndoChangesCommand}">
					<Grid ColumnDefinitions="Auto,*">
						<materialIcons:MaterialIcon Grid.Column="0" Kind="Undo"/>
						<TextBlock Grid.Column="1" Margin="5,0,0,0" VerticalAlignment="Center" Text="{x:Static lang:Resources.Undo}"/>
					</Grid>
				</Button>
				<Button Height="32" Margin="10,0,0,0"
						Command="{Binding SaveChangesCommand}">
					<Grid ColumnDefinitions="Auto,*">
						<materialIcons:MaterialIcon Grid.Column="0" Kind="ContentSave"/>
						<TextBlock Grid.Column="1" Margin="5,0,0,0" VerticalAlignment="Center" Text="{x:Static lang:Resources.Save}"/>
					</Grid>
				</Button>
			</StackPanel>

			<!-- Busy Indicator -->
			<Grid Grid.RowSpan="2"
				  Background="Black"
				  Opacity="0.5"
				  IsVisible="{Binding IsBusy}">
				<ProgressBar IsIndeterminate="True"
							 HorizontalAlignment="Center"
							 VerticalAlignment="Center"/>
			</Grid>
		</Grid>
	</DataTemplate>
</ResourceDictionary>

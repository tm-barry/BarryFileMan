<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:vm="using:BarryFileMan.ViewModels.Rename.Providers"
					xmlns:cc="using:BarryFileMan.Converters">
	<!-- Preview DataTemplate -->
	<Design.PreviewWith>
		<Grid Width="600" Height="450">
			<Grid.Resources>
				<ResourceDictionary>
					<ResourceDictionary.MergedDictionaries>
						<ResourceInclude Source="/Views/Rename/Providers/RegexRenameProviderViewTemplate.axaml"/>
					</ResourceDictionary.MergedDictionaries>
				</ResourceDictionary>
			</Grid.Resources>
			<Grid.DataTemplates>
				<StaticResource ResourceKey="regexRenameProviderView"/>
			</Grid.DataTemplates>

			<ContentControl>
				<vm:RegexRenameProviderViewModel/>
			</ContentControl>
		</Grid>
	</Design.PreviewWith>

	<DataTemplate x:Key="regexRenameProviderView" x:DataType="vm:RegexRenameProviderViewModel">
		<Grid>
			<Grid.Resources>
				<cc:IntToColorConverter x:Key="intToColorConverter"/>
			</Grid.Resources>
			
			<Grid.ColumnDefinitions>
				<ColumnDefinition/>
				<ColumnDefinition/>
			</Grid.ColumnDefinitions>

			<Grid Grid.Column="0" Margin="0,0,5,0">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition/>
					<RowDefinition Height="Auto"/>
					<RowDefinition/>
					<RowDefinition Height="Auto"/>
					<RowDefinition/>
					<RowDefinition Height="Auto"/>
					<RowDefinition/>
				</Grid.RowDefinitions>

				<TextBlock Grid.Row="0" Text="Match Pattern"/>
				<TextBox Grid.Row="1" Text="{Binding MatchPattern}"
						 TextWrapping="Wrap"
						 MaxHeight="100"/>

				<TextBlock Grid.Row="2" Margin="0,10,0,0"
						   Text="Test String"/>
				<TextBox Grid.Row="3" Text="{Binding TestString}"
						 TextWrapping="Wrap"
						 MaxHeight="100"/>

				<TextBlock Grid.Row="4" Margin="0,10,0,0"
						   Text="Rename Pattern"/>
				<TextBox Grid.Row="5" Text="{Binding RenamePattern}"
						 TextWrapping="Wrap"
						 MaxHeight="100"/>

				<TextBlock Grid.Row="6" Margin="0,10,0,0" 
						   Text="Renamed String"/>
				<TextBox Grid.Row="7" Text="{Binding RenamedTestString}"
						 IsReadOnly="True"
						 TextWrapping="Wrap"
						 MaxHeight="100"/>
			</Grid>

			<Grid Grid.Column="1" Margin="5,0,0,0">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition/>
				</Grid.RowDefinitions>
				
				<TextBlock x:Name="matchGroupsLabel" Grid.Row="0" 
						   Text="Match Groups"/>
				<TreeView Grid.Row="1"
						  BorderThickness="1"
						  BorderBrush="{Binding #matchGroupsLabel.Foreground}"
						  CornerRadius="3"
						  ItemsSource="{Binding TestMatchNodes}">
					<TreeView.Styles>
						<Style Selector="TreeViewItem">
							<Setter Property="IsExpanded" Value="True"/>
						</Style>
					</TreeView.Styles>
					
					<TreeView.ItemTemplate>
						<TreeDataTemplate ItemsSource="{Binding SubNodes}">
							<Grid Background="{Binding GroupKey, Converter={StaticResource intToColorConverter}}">
								<Grid.ColumnDefinitions>
									<ColumnDefinition/>
									<ColumnDefinition/>
								</Grid.ColumnDefinitions>

								<TextBlock Grid.Column="0" Padding="10,5"
										   Text="{Binding DisplayName}"
										   IsVisible="{Binding !HasValue}"
										   VerticalAlignment="Center"/>
								<TextBlock Grid.Column="0" Padding="10,5"
										   Text="{Binding DisplayName}"
										   Foreground="#FFFDFA"
										   IsVisible="{Binding HasValue}"
										   VerticalAlignment="Center"/>
								<TextBox Grid.Column="1" Margin="2"
										 Text="{Binding Value}"
										 IsReadOnly="True" 
										 IsVisible="{Binding HasValue}"/>
							</Grid>
						</TreeDataTemplate>
					</TreeView.ItemTemplate>
				</TreeView>
				
				<!-- Matches Placeholder -->
				<Grid Grid.Row="1" IsHitTestVisible="false" IsVisible="{Binding !HasTestMatches}">
					<TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
							   Text="No Matches Found"
							   Opacity="0.5"/>
				</Grid>
			</Grid>
		</Grid>
	</DataTemplate>
</ResourceDictionary>

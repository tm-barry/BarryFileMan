<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:vm="using:BarryFileMan.ViewModels.Rename.Providers"
					xmlns:vh="using:BarryFileMan.Views.Help"
					xmlns:cc="using:BarryFileMan.Converters"
					xmlns:he="using:BarryFileMan.Enums.Help"
					xmlns:lang="using:BarryFileMan.Resources"
					xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia">
	<!-- Preview DataTemplate -->
	<Design.PreviewWith>
		<Grid Width="600" Height="315">
			<Grid.Resources>
				<ResourceDictionary>
					<ResourceDictionary.MergedDictionaries>
						<ResourceInclude Source="/Views/Rename/Providers/RegexRenameProviderViewTemplate.axaml"/>
					</ResourceDictionary.MergedDictionaries>
				</ResourceDictionary>
			</Grid.Resources>
			<Grid.DataTemplates>
				<StaticResource ResourceKey="regexRenameProviderView"/>
			</Grid.DataTemplates>

			<ContentControl>
				<vm:RegexRenameProviderViewModel/>
			</ContentControl>
		</Grid>
	</Design.PreviewWith>

	<DataTemplate x:Key="regexRenameProviderView" x:DataType="vm:RegexRenameProviderViewModel">
		<Grid ColumnDefinitions="*,*" RowDefinitions="*,Auto">
			<Grid.Resources>
				<cc:IntToColorConverter x:Key="intToColorConverter"/>
			</Grid.Resources>

			<!-- Settings -->
			<Border Grid.Column="0" Grid.Row="0"
					Margin="0,0,5,0"
					BorderThickness="1" CornerRadius="3"
					BorderBrush="{DynamicResource SystemBaseMediumColor}">
				<ScrollViewer MaxHeight="250">
					<StackPanel Margin="10">
						<StackPanel Orientation="Horizontal">
							<TextBlock FontWeight="Bold"
								   Text="{x:Static lang:Resources.MatchPattern}"/>
							<vh:HelpButton Margin="5,0,0,0" Height="16" Width="16"
										   Section="{x:Static he:HelpSections.RenameRegex}"/>
						</StackPanel>
						<TextBox Text="{Binding MatchPattern}"
								 TextWrapping="Wrap"
								 MaxHeight="75"/>

						<TextBlock Margin="0,10,0,0"
								   FontWeight="Bold"
								   Text="{x:Static lang:Resources.MatchType}"/>
						<ComboBox HorizontalAlignment="Stretch"
								  ItemsSource="{Binding MatchTypes}"
								  DisplayMemberBinding="{Binding Display}"
								  SelectedIndex="{Binding SelectedMatchTypeIndex}"/>

						<StackPanel Orientation="Horizontal" Margin="0,10,0,0">
							<TextBlock FontWeight="Bold"
									   Text="{x:Static lang:Resources.RenamePattern}"/>
							<vh:HelpButton Margin="5,0,0,0" Height="16" Width="16"
										   Section="{x:Static he:HelpSections.Rename}"/>
						</StackPanel>
						<TextBox Text="{Binding RenamePattern}"
								 TextWrapping="Wrap"
								 MaxHeight="75"/>
					</StackPanel>
				</ScrollViewer>
			</Border>

			<!-- Matches -->
			<TreeView Grid.Column="1" Grid.Row="0"
			          Margin="5,0,0,0"
			          MaxHeight="250"
			          VerticalAlignment="Stretch"
			          BorderThickness="1"
			          BorderBrush="{DynamicResource SystemBaseMediumColor}"
			          CornerRadius="3"
			          ItemsSource="{Binding InputMatchNodes}">
				<TreeView.ItemTemplate>
					<TreeDataTemplate DataType="vm:RenameMatchNodeViewModel" ItemsSource="{Binding SubNodes}">
						<Grid ColumnDefinitions="*,*">
							<StackPanel Orientation="Horizontal" Grid.Column="0">
								<materialIcons:MaterialIcon Height="16" Width="16"
								                            Kind="{Binding Icon}"/>
								<TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" Margin="5,0,10,0"/>
							</StackPanel>
							<TextBlock Grid.Column="1" Text="{Binding Value}" VerticalAlignment="Center"/>
						</Grid>
					</TreeDataTemplate>
				</TreeView.ItemTemplate>

				<TreeView.Styles>
					<Style Selector="TreeViewItem" x:DataType="vm:RenameMatchNodeViewModel">
						<Setter Property="Background" Value="{Binding GroupKey, Converter={StaticResource intToColorConverter}}"/>
						<Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
					</Style>
				</TreeView.Styles>
			</TreeView>

			<!-- Matches Placeholder -->
			<Grid Grid.Column="1" Grid.Row="0"
				  Margin="5,0,0,0"
				  IsHitTestVisible="false" 
				  IsVisible="{Binding !HasInputMatches}">
				<TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
						   Text="{x:Static lang:Resources.NoMatchesFound}"
						   Opacity="0.5"/>
			</Grid>


			<!-- Input/Output -->
			<Grid Grid.Row="1" Grid.ColumnSpan="2" 
				  Margin="0,10,0,0">
				<Border Padding="10"
						BorderThickness="1" CornerRadius="3"
						BorderBrush="{DynamicResource SystemBaseMediumColor}">
					<Grid ColumnDefinitions="*,*">
						<!-- Input -->
						<StackPanel Grid.Column="0"
									Margin="0,0,5,0">
							<TextBlock FontWeight="Bold"
									   Text="{x:Static lang:Resources.Input}"/>
							<TextBox Text="{Binding Input}"
									 TextWrapping="Wrap"
									 MaxHeight="57"/>
						</StackPanel>

						<!-- Output -->
						<StackPanel Grid.Column="1"
									Margin="5,0,0,0">
							<TextBlock FontWeight="Bold"
									   Text="{x:Static lang:Resources.Output}"/>
							<Border BorderBrush="{DynamicResource SystemBaseMediumColor}"
									CornerRadius="3"
									BorderThickness="1">
								<ScrollViewer MaxHeight="57">
									<SelectableTextBlock Margin="3" Text="{Binding Output}"
														 TextWrapping="Wrap"
														 Background="Transparent"
														 HorizontalAlignment="Stretch"/>
								</ScrollViewer>
							</Border>
						</StackPanel>
					</Grid>
				</Border>
			</Grid>

			<!-- Busy Indicator -->
			<Grid Grid.RowSpan="2"
				  Grid.ColumnSpan="2"
				  Background="Black"
				  Opacity="0.5"
				  IsVisible="{Binding IsBusy}">
				<ProgressBar IsIndeterminate="True"
							 HorizontalAlignment="Center"
							 VerticalAlignment="Center"/>
			</Grid>
		</Grid>
	</DataTemplate>
</ResourceDictionary>

<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:vm="using:BarryFileMan.ViewModels.Rename.Providers">
	<!-- Preview DataTemplate -->
	<Design.PreviewWith>
		<Grid Width="600" Height="450">
			<Grid.Resources>
				<ResourceDictionary>
					<ResourceDictionary.MergedDictionaries>
						<ResourceInclude Source="/Views/Rename/Providers/RegexRenameProviderViewTemplate.axaml"/>
					</ResourceDictionary.MergedDictionaries>
				</ResourceDictionary>
			</Grid.Resources>
			<Grid.DataTemplates>
				<StaticResource ResourceKey="regexRenameProviderView"/>
			</Grid.DataTemplates>

			<ContentControl>
				<vm:RegexRenameProviderViewModel/>
			</ContentControl>
		</Grid>
	</Design.PreviewWith>

	<DataTemplate x:Key="regexRenameProviderView" x:DataType="vm:RegexRenameProviderViewModel">
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition/>
				<ColumnDefinition/>
			</Grid.ColumnDefinitions>
			<Grid.RowDefinitions>
				<RowDefinition/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,5,0">
				<StackPanel>
					<TextBlock Text="Match Pattern"/>
					<TextBox Text="{Binding MatchPattern}"
							 TextWrapping="Wrap"
							 MaxHeight="100"/>
				</StackPanel>
				<StackPanel Margin="0,10,0,0">
					<TextBlock Text="Rename Pattern"/>
					<TextBox Text="{Binding RenamePattern}"
							 TextWrapping="Wrap"
							 MaxHeight="100"/>
				</StackPanel>
			</StackPanel>

			<Grid Grid.Column="1" Grid.Row="0" Margin="5,0,0,0">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition/>
				</Grid.RowDefinitions>
				
				<TextBlock x:Name="matchGroupsLabel" Grid.Row="0" Text="Match Groups"/>
				<TreeView Grid.Row="1" MaxHeight="200"
						  BorderThickness="1"
						  BorderBrush="{Binding #matchGroupsLabel.Foreground}"
						  CornerRadius="3"
						  ItemsSource="{Binding TestMatchNodes}">
					<TreeView.Styles>
						<Style Selector="TreeViewItem">
							<Setter Property="IsExpanded" Value="True"/>
						</Style>
					</TreeView.Styles>
					
					<TreeView.ItemTemplate>
						<TreeDataTemplate ItemsSource="{Binding SubNodes}">
							<TextBlock Text="{Binding DisplayName}"/>
						</TreeDataTemplate>
					</TreeView.ItemTemplate>
				</TreeView>
				
				<!-- Matches Placeholder -->
				<Grid Grid.Row="1" IsHitTestVisible="false" IsVisible="{Binding !HasTestMatches}">
					<TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
							   Text="No Matches Found"
							   Opacity="0.5"/>
				</Grid>
			</Grid>

			<StackPanel Grid.Column="0" Grid.Row="1" Margin="0,10,5,0">
				<TextBlock Text="Test String"/>
				<TextBox Text="{Binding TestString}"
						 TextWrapping="Wrap"
						 MaxHeight="100"/>
			</StackPanel>
			<StackPanel Grid.Column="1" Grid.Row="1" Margin="5,10,0,0">
				<TextBlock Text="Renamed String"/>
				<TextBox Text="{Binding RenamedTestString}"
						 IsReadOnly="True"
						 TextWrapping="Wrap"
						 MaxHeight="100"/>
			</StackPanel>
		</Grid>
	</DataTemplate>
</ResourceDictionary>

<Button xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="100" d:DesignHeight="100"
        x:Class="BarryFileMan.Views.Help.HelpLink"
		x:Name="helpLink"
		Background="Transparent"
		BorderThickness="0"
		Click="HelpLink_Click">
	<Button.Template>
		<ControlTemplate>
			<TextBlock Text="{Binding #helpLink.Content}" Foreground="{DynamicResource SystemAccentColor}" TextDecorations="Underline">
				<TextBlock.Styles>
					<Style Selector="TextBlock:pointerover">
						<Setter Property="Foreground" Value="{DynamicResource SystemAccentColorLight1}"/>
					</Style>
				</TextBlock.Styles>
			</TextBlock>
		</ControlTemplate>
	</Button.Template>
</Button>

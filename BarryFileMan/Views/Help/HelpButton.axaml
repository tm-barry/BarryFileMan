<Button xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="100" d:DesignHeight="100"
        x:Class="BarryFileMan.Views.Help.HelpButton"
		x:Name="helpButton"
		Background="Transparent"
		BorderThickness="0"
		Click="HelpButton_Click">
	<Button.Template>
		<ControlTemplate>
			<materialIcons:MaterialIcon Height="{Binding #helpButton.IconHeight}" 
										Width="{Binding #helpButton.IconWidth}" 
										Kind="HelpCircle"
										Foreground="{DynamicResource SystemAccentColor}">
				<materialIcons:MaterialIcon.Styles>
					<Style Selector="materialIcons|MaterialIcon:pointerover">
						<Setter Property="Foreground" Value="{DynamicResource SystemAccentColorLight1}"/>
					</Style>
				</materialIcons:MaterialIcon.Styles>
			</materialIcons:MaterialIcon>
		</ControlTemplate>
	</Button.Template>
</Button>

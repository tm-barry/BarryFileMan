<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:vmhs="using:BarryFileMan.ViewModels.Help.Sections"
					xmlns:vc="using:BarryFileMan.Views.Common"
					xmlns:lang="using:BarryFileMan.Resources">
	<!-- Preview DataTemplate -->
	<Design.PreviewWith>
		<Grid Width="500" Height="500">
			<Grid.Resources>
				<ResourceDictionary>
					<ResourceDictionary.MergedDictionaries>
						<ResourceInclude Source="/Views/Help/Sections/RenameTMDBSectionViewTemplate.axaml"/>
					</ResourceDictionary.MergedDictionaries>
				</ResourceDictionary>
			</Grid.Resources>
			<Grid.DataTemplates>
				<StaticResource ResourceKey="renameTMDBSectionView"/>
			</Grid.DataTemplates>

			<ContentControl>
				<vmhs:RenameTMDBSectionViewModel/>
			</ContentControl>
		</Grid>
	</Design.PreviewWith>

	<DataTemplate x:Key="renameTMDBSectionView" x:DataType="vmhs:RenameTMDBSectionViewModel">
		<StackPanel>
			
			<!-- Rename TMDB Header -->
			<StackPanel Orientation="Horizontal">
				<Image Width="96"
				       Source="/Assets/tmdb-alt-short-logo.96x12.png"/>
				<TextBlock FontSize="32" FontWeight="Bold"
						   VerticalAlignment="Center"
						   TextWrapping="Wrap"
						   Text="{x:Static lang:Resources.RenameTMDBHelpTitle}"/>
			</StackPanel>
			<Separator Margin="0,5,0,5"/>

			<!-- Rename TMDB Description -->
			<TextBlock TextWrapping="Wrap"
					   Text="{x:Static lang:Resources.TMDBRenameMatchProviderDescription}"/>
			<vc:Hyperlink Content="{Binding TmdbAPIDocumentationUri}" Margin="0,10,0,0"/>

			<!-- Rename TMDB Options -->
			<TextBlock Margin="0,15,0,0"
					   FontSize="24" FontWeight="Bold"
					   VerticalAlignment="Center"
					   TextWrapping="Wrap"
					   Text="{x:Static lang:Resources.TMDBOptions}"/>
			<Separator Margin="0,5,0,5"/>

			<Grid ColumnDefinitions="Auto,Auto,*"
				  RowDefinitions="Auto,Auto,Auto,Auto,
								  Auto,Auto,Auto,Auto,
								  Auto,Auto,Auto,Auto">
				
				<!--Headers-->
				<TextBlock Grid.Column="0" Grid.Row="0" Margin="5"
						   FontWeight="Bold"
						   Text="{x:Static lang:Resources.Name}"/>
				<Border Grid.Column="1" Grid.RowSpan="100"
						Opacity="0.75"
						BorderBrush="{DynamicResource SystemBaseMediumColor}"
						BorderThickness="1,0,0,0"/>
				<TextBlock Grid.Column="2" Grid.Row="0" Margin="5"
						   FontWeight="Bold"
						   Text="{x:Static lang:Resources.Description}"/>
				<Border Grid.ColumnSpan="3" Grid.Row="1" Padding="0"
						Opacity="0.75"
						BorderBrush="{DynamicResource SystemBaseMediumColor}"
						BorderThickness="0,1,0,0"/>

				<!-- Query -->
				<TextBlock Grid.Column="0" Grid.Row="2" Margin="10"
						   FontWeight="Bold" Classes="cell-text"
						   VerticalAlignment="Center"
						   Text="{x:Static lang:Resources.Query}"/>
				<TextBlock Grid.Column="2" Grid.Row="2" Margin="10"
						   TextWrapping="Wrap" Classes="cell-text"
						   Text="{x:Static lang:Resources.RenameTMDBQueryDescription}"/>
				<Border Grid.ColumnSpan="3" Grid.Row="3" Padding="0"
						Opacity="0.75"
						BorderBrush="{DynamicResource SystemBaseMediumColor}"
						BorderThickness="0,1,0,0"/>

				<!-- Year -->
				<TextBlock Grid.Column="0" Grid.Row="4" Margin="10"
						   FontWeight="Bold" Classes="cell-text"
						   VerticalAlignment="Center"
						   Text="{x:Static lang:Resources.Year}"/>
				<TextBlock Grid.Column="2" Grid.Row="4" Margin="10"
						   TextWrapping="Wrap" Classes="cell-text"
						   Text="{x:Static lang:Resources.RenameTMDBYearDescription}"/>
				<Border Grid.ColumnSpan="3" Grid.Row="5" Padding="0"
						Opacity="0.75"
						BorderBrush="{DynamicResource SystemBaseMediumColor}"
						BorderThickness="0,1,0,0"/>

				<!-- Season -->
				<TextBlock Grid.Column="0" Grid.Row="6" Margin="10"
						   FontWeight="Bold" Classes="cell-text"
						   VerticalAlignment="Center"
						   Text="{x:Static lang:Resources.Season}"/>
				<TextBlock Grid.Column="2" Grid.Row="6" Margin="10"
						   TextWrapping="Wrap" Classes="cell-text"
						   Text="{x:Static lang:Resources.RenameTMDBSeasonDescription}"/>
				<Border Grid.ColumnSpan="3" Grid.Row="7" Padding="0"
						Opacity="0.75"
						BorderBrush="{DynamicResource SystemBaseMediumColor}"
						BorderThickness="0,1,0,0"/>

				<!-- Episode -->
				<TextBlock Grid.Column="0" Grid.Row="8" Margin="10"
						   FontWeight="Bold" Classes="cell-text"
						   VerticalAlignment="Center"
						   Text="{x:Static lang:Resources.Episode}"/>
				<TextBlock Grid.Column="2" Grid.Row="8" Margin="10"
						   TextWrapping="Wrap" Classes="cell-text"
						   Text="{x:Static lang:Resources.RenameTMDBEpisodeDescription}"/>
				<Border Grid.ColumnSpan="3" Grid.Row="9" Padding="0"
						Opacity="0.75"
						BorderBrush="{DynamicResource SystemBaseMediumColor}"
						BorderThickness="0,1,0,0"/>

				<!-- Language -->
				<TextBlock Grid.Column="0" Grid.Row="10" Margin="10"
						   FontWeight="Bold" Classes="cell-text"
						   VerticalAlignment="Center"
						   Text="{x:Static lang:Resources.Language}"/>
				<TextBlock Grid.Column="2" Grid.Row="10" Margin="10"
						   TextWrapping="Wrap" Classes="cell-text"
						   Text="{x:Static lang:Resources.RenameTMDBLanguageDescription}"/>
				<Border Grid.ColumnSpan="3" Grid.Row="11" Padding="0"
						Opacity="0.75"
						BorderBrush="{DynamicResource SystemBaseMediumColor}"
						BorderThickness="0,1,0,0"/>
			</Grid>
			
		</StackPanel>
	</DataTemplate>
</ResourceDictionary>

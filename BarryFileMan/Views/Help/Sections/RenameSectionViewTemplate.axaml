<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:vm="using:BarryFileMan.ViewModels.Help.Sections"
					xmlns:vc="using:BarryFileMan.Views.Common"
					xmlns:help="using:BarryFileMan.Views.Help"
					xmlns:lang="using:BarryFileMan.Resources"
					xmlns:enums="using:BarryFileMan.Enums.Help"
					xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia">
	<!-- Preview DataTemplate -->
	<Design.PreviewWith>
		<Grid Width="500" Height="2048">
			<Grid.Resources>
				<ResourceDictionary>
					<ResourceDictionary.MergedDictionaries>
						<ResourceInclude Source="/Views/Help/Sections/RenameSectionViewTemplate.axaml"/>
					</ResourceDictionary.MergedDictionaries>
				</ResourceDictionary>
			</Grid.Resources>
			<Grid.DataTemplates>
				<StaticResource ResourceKey="renameSectionView"/>
			</Grid.DataTemplates>

			<ContentControl>
				<vm:RenameSectionViewModel/>
			</ContentControl>
		</Grid>
	</Design.PreviewWith>

	<DataTemplate x:Key="renameSectionView" x:DataType="vm:RenameSectionViewModel">
		<StackPanel>
			
			<!-- Rename Header -->
			<StackPanel Orientation="Horizontal">
				<materialIcons:MaterialIcon Height="24" Width="24" Margin="0,0,5,0"
											Kind="Rename"/>
				<TextBlock FontSize="32" FontWeight="Bold"
						   VerticalAlignment="Center"
						   TextWrapping="Wrap"
						   Text="{x:Static lang:Resources.Rename}"/>
			</StackPanel>
			<Separator Margin="0,5,0,5"/>

			<!-- Rename Description -->
			<TextBlock TextWrapping="Wrap"
					   Text="{x:Static lang:Resources.RenamePageDescription}"/>

			<!-- Rename Match Providers -->
			<TextBlock Margin="0,15,0,0"
					   FontSize="24" FontWeight="Bold"
					   VerticalAlignment="Center"
					   TextWrapping="Wrap"
					   Text="{x:Static lang:Resources.RenameMatchProviders}"/>
			<Separator Margin="0,5,0,5"/>

			<Grid ColumnDefinitions="Auto,Auto,*"
				  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">

				<!--Headers-->
				<TextBlock Grid.Column="0" Grid.Row="0" Margin="5"
						   FontWeight="Bold"
						   Text="{x:Static lang:Resources.Name}"/>
				<Border Grid.Column="1" Grid.RowSpan="100"
						Opacity="0.75"
						BorderBrush="{DynamicResource SystemBaseMediumColor}"
						BorderThickness="1,0,0,0"/>
				<TextBlock Grid.Column="2" Grid.Row="0" Margin="5"
						   FontWeight="Bold"
						   Text="{x:Static lang:Resources.Description}"/>
				<Border Grid.ColumnSpan="3" Grid.Row="1" Padding="0"
						Opacity="0.75"
						BorderBrush="{DynamicResource SystemBaseMediumColor}"
						BorderThickness="0,1,0,0"/>

				<!--Regex-->
				<help:HelpLink Grid.Column="0" Grid.Row="2" Margin="10"
							   FontWeight="Bold" Classes="cell-text"
							   Content="{x:Static lang:Resources.Regex}"
							   VerticalAlignment="Center"
							   Section="{x:Static enums:HelpSections.RenameRegex}"/>
				<TextBlock Grid.Column="2" Grid.Row="2" Margin="10"
						   TextWrapping="Wrap" Classes="cell-text"
						   Text="{x:Static lang:Resources.RegexRenameMatchProviderDescription}"/>
				<Border Grid.ColumnSpan="3" Grid.Row="3" Padding="0"
						Opacity="0.75"
						BorderBrush="{DynamicResource SystemBaseMediumColor}"
						BorderThickness="0,1,0,0"/>

				<!--TMDB-->
				<help:HelpLink Grid.Column="0" Grid.Row="4" Margin="10"
							   FontWeight="Bold" Classes="cell-text"
							   Content="{x:Static lang:Resources.TMDB}"
							   VerticalAlignment="Center"
							   Section="{x:Static enums:HelpSections.RenameTMDB}"/>
				<TextBlock Grid.Column="2" Grid.Row="4" Margin="10"
						   TextWrapping="Wrap" Classes="cell-text"
						   Text="{x:Static lang:Resources.TMDBRenameMatchProviderDescription}"/>
				<Border Grid.ColumnSpan="3" Grid.Row="5" Padding="0"
						Opacity="0.75"
						BorderBrush="{DynamicResource SystemBaseMediumColor}"
						BorderThickness="0,1,0,0"/>
			</Grid>

			<!-- Rename Pattern Syntax Header -->
			<TextBlock Margin="0,15,0,0"
					   FontSize="24" FontWeight="Bold"
					   VerticalAlignment="Center"
					   TextWrapping="Wrap"
					   Text="{x:Static lang:Resources.RenamePatternSyntax}"/>
			<Separator Margin="0,5,0,5"/>

			<!-- Rename Pattern Syntax Description -->
			<TextBlock TextWrapping="Wrap"
					   Text="{x:Static lang:Resources.RenamePatternSyntaxDescription}"/>

			<!-- Rename Pattern Tag Match Index Syntax Header -->
			<TextBlock Margin="10,15,0,0"
					   FontSize="18" FontWeight="Bold"
					   VerticalAlignment="Center"
					   TextWrapping="Wrap"
					   Text="{x:Static lang:Resources.TagMatchIndex}"/>

			<!-- Rename Pattern Tag Match Index Description -->
			<TextBlock Margin="10,10,0,0" TextWrapping="Wrap"
					   Text="{x:Static lang:Resources.TagMatchIndexDescription}"/>

			<!-- Rename Pattern Tag Match Index Example -->
			<SelectableTextBlock Margin="20,10,0,0" TextWrapping="Wrap"
					   FontWeight="Medium" FontSize="12"
					   Text="{x:Static lang:Resources.TagMatchIndexExample}"/>

			<!-- Rename Pattern Tag Group Index Syntax Header -->
			<TextBlock Margin="10,15,0,0"
					   FontSize="18" FontWeight="Bold"
					   VerticalAlignment="Center"
					   TextWrapping="Wrap"
					   Text="{x:Static lang:Resources.TagGroupIndex}"/>

			<!-- Rename Pattern Tag Group Index Description -->
			<TextBlock Margin="10,10,0,0" TextWrapping="Wrap"
					   Text="{x:Static lang:Resources.TagGroupIndexDescription}"/>

			<!-- Rename Pattern Tag Group Index Example -->
			<SelectableTextBlock Margin="20,10,0,0" TextWrapping="Wrap"
					   FontWeight="Medium" FontSize="12"
					   Text="{x:Static lang:Resources.TagGroupIndexExample}"/>

			<!-- Rename Pattern Tag Format Functions Header -->
			<TextBlock Margin="10,15,0,0"
					   FontSize="18" FontWeight="Bold"
					   VerticalAlignment="Center"
					   TextWrapping="Wrap"
					   Text="{x:Static lang:Resources.TagFormatFunctions}"/>

			<!-- Rename Pattern Tag Format Functions Description -->
			<TextBlock Margin="10,10,0,0" TextWrapping="Wrap"
					   Text="{x:Static lang:Resources.TagFormatFunctionsDescription}"/>

			<!-- Rename Pattern Tag Match Index Example -->
			<SelectableTextBlock Margin="20,10,0,0" TextWrapping="Wrap"
					   FontWeight="Medium" FontSize="12"
					   Text="{x:Static lang:Resources.TagFormatFunctionsExample}"/>

			<!-- Rename Pattern Fallback Header -->
			<TextBlock Margin="10,15,0,0"
					   FontSize="18" FontWeight="Bold"
					   VerticalAlignment="Center"
					   TextWrapping="Wrap"
					   Text="{x:Static lang:Resources.TagFallback}"/>

			<!-- Rename Pattern Fallback Description -->
			<TextBlock Margin="10,10,0,0" TextWrapping="Wrap"
					   Text="{x:Static lang:Resources.TagFallbackDescription}"/>

			<!-- Rename Pattern Fallback Example -->
			<SelectableTextBlock Margin="20,10,0,0" TextWrapping="Wrap"
					   FontWeight="Medium" FontSize="12"
					   Text="{x:Static lang:Resources.TagFallbackExample}"/>

			<Grid Margin="10,30,0,0"
				  ColumnDefinitions="*,Auto,*"
				  RowDefinitions="Auto,Auto,Auto,Auto,
								  Auto,Auto,Auto,Auto,
								  Auto,Auto,Auto,Auto
								  Auto, Auto">

				<!--Headers-->
				<TextBlock Grid.Column="0" Grid.Row="0" Margin="5"
						   FontWeight="Bold"
						   Text="{x:Static lang:Resources.Function}"/>
				<Border Grid.Column="1" Grid.RowSpan="100"
						Opacity="0.75"
						BorderBrush="{DynamicResource SystemBaseMediumColor}"
						BorderThickness="1,0,0,0"/>
				<TextBlock Grid.Column="2" Grid.Row="0" Margin="5"
						   FontWeight="Bold"
						   Text="{x:Static lang:Resources.Example}"/>
				<Border Grid.ColumnSpan="3" Grid.Row="1" Padding="0"
						Opacity="0.75"
						BorderBrush="{DynamicResource SystemBaseMediumColor}"
						BorderThickness="0,1,0,0"/>

				<!--Append-->
				<StackPanel Grid.Column="0" Grid.Row="2" Margin="10">
					<TextBlock Margin="0,0,0,5"
							   FontWeight="Bold" Classes="cell-text"
							   TextWrapping="Wrap"
						       Text="{x:Static lang:Resources.FunctionAppendDefinition}"/>
					<TextBlock Margin="0,0,0,10"
							   FontWeight="Bold" Classes="cell-text"
							   TextWrapping="Wrap"
						       Text="{x:Static lang:Resources.FunctionAppendCompactDefinition}"/>
					<TextBlock Margin="0,0,0,10" xml:space="preserve"
							   FontWeight="Medium" Classes="cell-text"
							   TextWrapping="Wrap"
						       Text="{x:Static lang:Resources.FunctionAppendParams}"/>
					<TextBlock Classes="cell-text"
							   TextWrapping="Wrap"
						       Text="{x:Static lang:Resources.FunctionAppendDescription}"/>
				</StackPanel>
				<StackPanel Grid.Column="2" Grid.Row="2" Margin="10">
					<SelectableTextBlock Margin="0,0,0,5" TextWrapping="Wrap" Classes="cell-text"
										 Text="{x:Static lang:Resources.FunctionAppendExample}"/>
					<SelectableTextBlock TextWrapping="Wrap" Classes="cell-text"
										 Text="{x:Static lang:Resources.FunctionAppendCompactExample}"/>
				</StackPanel>
				<Border Grid.ColumnSpan="3" Grid.Row="3" Padding="0"
						Opacity="0.75"
						BorderBrush="{DynamicResource SystemBaseMediumColor}"
						BorderThickness="0,1,0,0"/>

				<!--Pad-->
				<StackPanel Grid.Column="0" Grid.Row="4" Margin="10">
					<TextBlock Margin="0,0,0,5" 
							   FontWeight="Bold" Classes="cell-text"
							   TextWrapping="Wrap"
						       Text="{x:Static lang:Resources.FunctionPadDefinition}"/>
					<TextBlock Margin="0,0,0,10"
							   FontWeight="Bold" Classes="cell-text"
							   TextWrapping="Wrap"
						       Text="{x:Static lang:Resources.FunctionPadCompactDefinition}"/>
					<TextBlock Margin="0,0,0,10" xml:space="preserve"
							   FontWeight="Medium" Classes="cell-text"
							   TextWrapping="Wrap"
						       Text="{x:Static lang:Resources.FunctionPadParams}"/>
					<TextBlock Classes="cell-text"
							   TextWrapping="Wrap"
						       Text="{x:Static lang:Resources.FunctionPadDescription}"/>
				</StackPanel>
				<StackPanel Grid.Column="2" Grid.Row="4" Margin="10">
					<SelectableTextBlock Margin="0,0,0,5" TextWrapping="Wrap" Classes="cell-text"
										 Text="{x:Static lang:Resources.FunctionPadExample}"/>
					<SelectableTextBlock TextWrapping="Wrap" Classes="cell-text"
										 Text="{x:Static lang:Resources.FunctionPadCompactExample}"/>
				</StackPanel>
				<Border Grid.ColumnSpan="3" Grid.Row="5" Padding="0"
						Opacity="0.75"
						BorderBrush="{DynamicResource SystemBaseMediumColor}"
						BorderThickness="0,1,0,0"/>

				<!--Prepend-->
				<StackPanel Grid.Column="0" Grid.Row="6" Margin="10">
					<TextBlock Margin="0,0,0,5"
							   FontWeight="Bold" Classes="cell-text"
							   TextWrapping="Wrap"
						       Text="{x:Static lang:Resources.FunctionPrependDefinition}"/>
					<TextBlock Margin="0,0,0,10"
							   FontWeight="Bold" Classes="cell-text"
							   TextWrapping="Wrap"
						       Text="{x:Static lang:Resources.FunctionPrependCompactDefinition}"/>
					<TextBlock Margin="0,0,0,10" xml:space="preserve"
							   FontWeight="Medium" Classes="cell-text"
							   TextWrapping="Wrap"
						       Text="{x:Static lang:Resources.FunctionPrependParams}"/>
					<TextBlock Classes="cell-text"
							   TextWrapping="Wrap"
						       Text="{x:Static lang:Resources.FunctionPrependDescription}"/>
				</StackPanel>
				<StackPanel Grid.Column="2" Grid.Row="6" Margin="10">
					<SelectableTextBlock Margin="0,0,0,5" TextWrapping="Wrap" Classes="cell-text"
										 Text="{x:Static lang:Resources.FunctionPrependExample}"/>
					<SelectableTextBlock TextWrapping="Wrap" Classes="cell-text"
										 Text="{x:Static lang:Resources.FunctionPrependCompactExample}"/>
				</StackPanel>
				<Border Grid.ColumnSpan="3" Grid.Row="7" Padding="0"
						Opacity="0.75"
						BorderBrush="{DynamicResource SystemBaseMediumColor}"
						BorderThickness="0,1,0,0"/>

				<!--Replace-->
				<StackPanel Grid.Column="0" Grid.Row="8" Margin="10">
					<TextBlock Margin="0,0,0,5"
							   FontWeight="Bold" Classes="cell-text"
							   TextWrapping="Wrap"
							   Text="{x:Static lang:Resources.FunctionReplaceDefinition}"/>
					<TextBlock Margin="0,0,0,10"
							   FontWeight="Bold" Classes="cell-text"
							   TextWrapping="Wrap"
							   Text="{x:Static lang:Resources.FunctionReplaceCompactDefinition}"/>
					<TextBlock Margin="0,0,0,10" xml:space="preserve"
							   FontWeight="Medium" Classes="cell-text"
							   TextWrapping="Wrap"
							   Text="{x:Static lang:Resources.FunctionReplaceParams}"/>
					<TextBlock Classes="cell-text"
							   TextWrapping="Wrap"
							   Text="{x:Static lang:Resources.FunctionReplaceDescription}"/>
				</StackPanel>
				<StackPanel Grid.Column="2" Grid.Row="8" Margin="10">
					<SelectableTextBlock Margin="0,0,0,5" TextWrapping="Wrap" Classes="cell-text"
										 Text="{x:Static lang:Resources.FunctionReplaceExample}"/>
					<SelectableTextBlock TextWrapping="Wrap" Classes="cell-text"
										 Text="{x:Static lang:Resources.FunctionReplaceCompactExample}"/>
				</StackPanel>
				<Border Grid.ColumnSpan="3" Grid.Row="9" Padding="0"
						Opacity="0.75"
						BorderBrush="{DynamicResource SystemBaseMediumColor}"
						BorderThickness="0,1,0,0"/>
				
				<!--Separate-->
				<StackPanel Grid.Column="0" Grid.Row="10" Margin="10">
					<TextBlock Margin="0,0,0,5"
					           FontWeight="Bold" Classes="cell-text"
					           TextWrapping="Wrap"
					           Text="{x:Static lang:Resources.FunctionSeparateDefinition}"/>
					<TextBlock Margin="0,0,0,5"
					           FontWeight="Bold" Classes="cell-text"
					           TextWrapping="Wrap"
					           Text="{x:Static lang:Resources.FunctionSeparateCompactDefinition}"/>
					<TextBlock Classes="cell-text"
					           TextWrapping="Wrap"
					           Text="{x:Static lang:Resources.FunctionSeparateDescription}"/>
				</StackPanel>
				<StackPanel Grid.Column="2" Grid.Row="10" Margin="10">
					<SelectableTextBlock Margin="0,0,0,5" TextWrapping="Wrap" Classes="cell-text"
					                     Text="{x:Static lang:Resources.FunctionSeparateExample}"/>
					<SelectableTextBlock TextWrapping="Wrap" Classes="cell-text"
					                     Text="{x:Static lang:Resources.FunctionSeparateCompactExample}"/>
				</StackPanel>
				<Border Grid.ColumnSpan="3" Grid.Row="11" Padding="0"
				        Opacity="0.75"
				        BorderBrush="{DynamicResource SystemBaseMediumColor}"
				        BorderThickness="0,1,0,0"/>

				<!--Trim-->
				<StackPanel Grid.Column="0" Grid.Row="12" Margin="10">
					<TextBlock Margin="0,0,0,5"
							   FontWeight="Bold" Classes="cell-text"
							   TextWrapping="Wrap"
							   Text="{x:Static lang:Resources.FunctionTrimDefinition}"/>
					<TextBlock Margin="0,0,0,5"
							   FontWeight="Bold" Classes="cell-text"
							   TextWrapping="Wrap"
							   Text="{x:Static lang:Resources.FunctionTrimCompactDefinition}"/>
					<TextBlock Margin="0,0,0,5" xml:space="preserve"
							   FontWeight="Medium" Classes="cell-text"
							   TextWrapping="Wrap"
							   Text="{x:Static lang:Resources.FunctionTrimParams}"/>
					<TextBlock Classes="cell-text"
							   TextWrapping="Wrap"
							   Text="{x:Static lang:Resources.FunctionTrimDescription}"/>
				</StackPanel>
				<StackPanel Grid.Column="2" Grid.Row="12" Margin="10">
					<SelectableTextBlock Margin="0,0,0,5" TextWrapping="Wrap" Classes="cell-text"
										 Text="{x:Static lang:Resources.FunctionTrimExample}"/>
					<SelectableTextBlock TextWrapping="Wrap" Classes="cell-text"
										 Text="{x:Static lang:Resources.FunctionTrimCompactExample}"/>
				</StackPanel>
				<Border Grid.ColumnSpan="3" Grid.Row="13" Padding="0"
						Opacity="0.75"
						BorderBrush="{DynamicResource SystemBaseMediumColor}"
						BorderThickness="0,1,0,0"/>
			</Grid>
			
		</StackPanel>
	</DataTemplate>
</ResourceDictionary>
